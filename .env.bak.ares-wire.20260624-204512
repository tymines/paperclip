# DATABASE_URL — leave unset to use embedded PostgreSQL (auto-managed)
# DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip

PORT=3100

# Serve the UI from the API server
SERVE_UI=true

# Authentication & Security
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=public
PAPERCLIP_AUTH_DISABLE_SIGN_UP=true
PAPERCLIP_PUBLIC_URL=https://paperclip.augiport.com
PAPERCLIP_ALLOWED_HOSTNAMES=paperclip.augiport.com
PAPERCLIP_AUTH_BASE_URL_MODE=explicit
PAPERCLIP_AUTH_PUBLIC_BASE_URL=https://paperclip.augiport.com

# OpenClaw Gateway — Tyler's stack
# Used as adapterConfig.url (ws://) when creating openclaw_gateway agents
# Gateway: ws://127.0.0.1:18789
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# Default agent for OpenDesign runs — switch from claude to codex
# to avoid burning Claude Max budget
OD_DEFAULT_AGENT=codex
