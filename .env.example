DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=paperclip-dev-secret

# Discord webhook for daily merge digest (scripts/discord-daily-digest.sh)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- Jarvis peer delegation: Ares (Box 2 / augibot2) ---
# War Room "Approve & send to team" → dispatchDelegation() POSTs to
# {JARVIS_PEER_ARES_URL}/jarvis/dispatch as identity "ares" (Bearer JARVIS_PEER_ARES_TOKEN),
# then Ares POSTs the result back to /jarvis/delegations/:id/result to flip the row to completed.
# Runtime values are set in ~/.paperclip/instances/default/.env on Box 1 (secret not committed).
# JARVIS_PEER_ARES_URL=http://augibot2s-mac-mini.tail1537c5.ts.net:18790
# JARVIS_PEER_ARES_TOKEN=<shared bearer; == AUGUST_GATEWAY_TOKEN on augibot2>
# PAPERCLIP_BRIDGE_LOCAL_API_URL=http://<box1-tailnet-ip>:3100   # so Ares can reach the result callback
