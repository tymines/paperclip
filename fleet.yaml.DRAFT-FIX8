  # ═══ Hephaestus (NEW — registered in DB, not in previous fleet.yaml) ═══
  - name: Hephaestus
    box: windows                 # LIVE: Windows (Box 3 per metadata, but Windows host)
    orchestrator: null           # TOP-LEVEL, reports to Tyler directly
    role: debug-rescue-specialist
    model: kimi-k2.6             # LIVE (DB): kimi-k2.6 primary, deepseek-v4-pro fallback
    framework: hermes
    standalone: true
    no_openai: true              # LIVE (DB): no_openai=True
