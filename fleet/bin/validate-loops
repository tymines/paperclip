#!/usr/bin/env python3
"""Validate loops.yaml parses and has required structure."""
import sys, yaml
from pathlib import Path

reg = Path(sys.argv[1] if len(sys.argv) > 1 else "paperclip/fleet/loops.yaml")

data = yaml.safe_load(reg.read_text())
assert "meta" in data, "missing meta"
assert "loops" in data, "missing loops"

for lid, spec in data["loops"].items():
    assert "owner" in spec, f"{lid}: missing owner"
    assert "trigger" in spec, f"{lid}: missing trigger"
    assert "budget" in spec, f"{lid}: missing budget"
    assert "exits" in spec, f"{lid}: missing exits"
    # verify is optional (meta-loops like L5.revision skip it)

print(f"OK: {len(data['loops'])} loops valid")
