import React, { useState, useEffect, useCallback } from "react";
import { useSelectedCompany } from "@/hooks/useSelectedCompany";
import { useQuery, useMutation } from "@tanstack/react-query";
import { bookWritingApi } from "@/api/bookWriting";

// ─── Simple icon components ─────────────────────────────────────────
function BookOpenIcon(props) { return (/* lucide book-open */<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>);
function DownloadIcon(props) { return (<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>);
function LoaderIcon(props) { return (<svg className="animate-spin" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><circle cx="12" cy="12" r="10" strokeDasharray="60" strokeDashoffset="20"/></svg>);

export function BookWritingPage() {
  const { company, companyId } = useSelectedCompany();
  
  // ─── Form State ──────────────────────────────────────
  const [concept, setConcept] = useState("");
  const [genre, setGenre] = useState("fantasy");
  const [length, setLength] = useState("novella");
  const [voice, setVoice] = useState("lyrical");
  const [pipelineId, setPipelineId] = useState(null);
  const [pipelineStatus, setPipelineStatus] = useState(null);
  const [artifacts, setArtifacts] = useState(null);

  // ─── Start Pipeline ───────────────────────────────────
  const startMutation = useMutation({
    mutationFn: () => bookWritingApi.start(companyId, { concept, genre, length, voice }),
    onSuccess: (data) => {
      setPipelineId(data.pipelineId);
      setPipelineStatus({ phase: "foundation", status: "starting" });
    },
  });

  // ─── Poll Status ──────────────────────────────────────
  const { data: statusData } = useQuery({
    queryKey: ["book-writing", "status", pipelineId],
    queryFn: () => bookWritingApi.status(companyId, pipelineId),
    enabled: !!pipelineId,
    refetchInterval: 5000,
    onSuccess: (data) => {
      setPipelineStatus(data);
      if (data.status === "complete") {
        bookWritingApi.artifacts(companyId, pipelineId).then(setArtifacts);
      }
    },
  });

  // ─── Phase display ────────────────────────────────────
  const phases = [
    { key: "seed", label: "Seed", weight: 5 },
    { key: "world", label: "World Building", weight: 20 },
    { key: "characters", label: "Characters", weight: 15 },
    { key: "outline", label: "Outline", weight: 15 },
    { key: "draft", label: "Drafting", weight: 30 },
    { key: "revision", label: "Revision", weight: 10 },
    { key: "export", label: "Export", weight: 5 },
  ];

  const currentPhase = pipelineStatus?.phase || "idle";
  const progress = phases.reduce((acc, p) => {
    const phaseOrder = phases.map(x => x.key);
    const currentIdx = phaseOrder.indexOf(currentPhase);
    const phaseIdx = phaseOrder.indexOf(p.key);
    if (phaseIdx < currentIdx) return acc + p.weight;
    if (phaseIdx === currentIdx) return acc + (p.weight * (pipelineStatus?.progress || 0)) / 100;
    return acc;
  }, 0);

  const canStart = concept.length > 10 && !startMutation.isPending && !pipelineId;

  return (
    <div className="flex flex-col h-full p-6 gap-6 bg-background">
      <header className="flex items-center gap-3">
        <div className="p-2 rounded-lg bg-primary/10 text-primary"><BookOpenIcon /></div>
        <div>
          <h1 className="text-xl font-semibold text-foreground">Book Writing</h1>
          <p className="text-sm text-muted-foreground">
            {company?.name ? `Writing for ${company.name}` : "Create a novel with AI"}
          </p>
        </div>
      </header>

      <div className="grid grid-cols-[380px_1fr_280px] gap-5 flex-1 min-h-0">
        {/* ─── INTAKE PANEL ─────────────────────────────── */}
        <div className="rounded-lg border border-border bg-card p-4 space-y-4 overflow-y-auto">
          <h2 className="text-sm font-semibold text-foreground">Book Concept</h2>
          
          <div className="space-y-2">
            <label className="text-xs text-muted-foreground">Concept / Seed</label>
            <textarea
              className="w-full min-h-[120px] rounded-md border border-border bg-background px-3 py-2 text-sm resize-y"
              placeholder="Describe your book concept... (e.g., 'In a world where magic costs memories, a young artisan must decide what to forget')"
              value={concept}
              onChange={(e) => setConcept(e.target.value)}
              disabled={!!pipelineId}
            />
          </div>

          <div className="grid grid-cols-2 gap-3">
            <div className="space-y-2">
              <label className="text-xs text-muted-foreground">Genre</label>
              <select className="w-full rounded-md border border-border bg-background px-3 py-2 text-sm"
                value={genre} onChange={(e) => setGenre(e.target.value)} disabled={!!pipelineId}>
                <option value="fantasy">Fantasy</option>
                <option value="scifi">Sci-Fi</option>
                <option value="mystery">Mystery</option>
                <option value="romance">Romance</option>
                <option value="thriller">Thriller</option>
                <option value="literary">Literary</option>
                <option value="historical">Historical</option>
                <option value="horror">Horror</option>
              </select>
            </div>

            <div className="space-y-2">
              <label className="text-xs text-muted-foreground">Length</label>
              <select className="w-full rounded-md border border-border bg-background px-3 py-2 text-sm"
                value={length} onChange={(e) => setLength(e.target.value)} disabled={!!pipelineId}>
                <option value="short_story">Short Story</option>
                <option value="novella">Novella</option>
                <option value="novel">Novel</option>
                <option value="epic">Epic</option>
              </select>
            </div>
          </div>

          <div className="space-y-2">
            <label className="text-xs text-muted-foreground">Tone / Voice</label>
            <select className="w-full rounded-md border border-border bg-background px-3 py-2 text-sm"
              value={voice} onChange={(e) => setVoice(e.target.value)} disabled={!!pipelineId}>
              <option value="lyrical">Lyrical</option>
              <option value="gritty">Gritty</option>
              <option value="academic">Academic</option>
              <option value="whimsical">Whimsical</option>
              <option value="minimalist">Minimalist</option>
              <option value="cinematic">Cinematic</option>
            </select>
          </div>

          <button
            className="w-full rounded-md bg-primary text-primary-foreground px-4 py-2 text-sm font-medium hover:bg-primary/90 disabled:opacity-50 disabled:cursor-not-allowed"
            onClick={() => startMutation.mutate()}
            disabled={!canStart}
          >
            {startMutation.isPending ? "Starting..." : "🚀 Start Writing"}
          </button>

          {pipelineId && (
            <button
              className="w-full rounded-md border border-border text-muted-foreground px-4 py-2 text-sm hover:bg-accent"
              onClick={() => {
                bookWritingApi.cancel(companyId, pipelineId);
                setPipelineId(null);
                setPipelineStatus(null);
              }}
            >
              Cancel
            </button>
          )}
        </div>

        {/* ─── DASHBOARD ────────────────────────────────── */}
        <div className="rounded-lg border border-border bg-card p-4 space-y-4 overflow-y-auto">
          {!pipelineId ? (
            <div className="flex flex-col items-center justify-center h-full text-center text-muted-foreground gap-4">
              <BookOpenIcon style={{ width: 48, height: 48, opacity: 0.3 }} />
              <div>
                <p className="text-sm font-medium">Enter a concept above and click Start Writing</p>
                <p className="text-xs mt-1">The fleet will autonomously build world, characters, outline, and chapters</p>
              </div>
            </div>
          ) : (
            <>
              <div className="flex items-center justify-between">
                <h2 className="text-sm font-semibold text-foreground">Pipeline Progress</h2>
                <span className="text-xs text-muted-foreground">
                  {pipelineStatus?.phase || "starting..."}
                </span>
              </div>

              {/* Progress bar */}
              <div className="h-2 rounded-full bg-muted overflow-hidden">
                <div className="h-full rounded-full bg-primary transition-all duration-500"
                  style={{ width: `${Math.min(progress, 100)}%` }} />
              </div>

              {/* Phase list */}
              <div className="space-y-2">
                {phases.map((p) => {
                  const phaseOrder = phases.map(x => x.key);
                  const currentIdx = phaseOrder.indexOf(currentPhase);
                  const phaseIdx = phaseOrder.indexOf(p.key);
                  let status = phaseIdx < currentIdx ? "done" : phaseIdx === currentIdx ? "active" : "pending";
                  return (
                    <div key={p.key} className="flex items-center gap-3 text-sm">
                      <div className={`w-5 h-5 rounded-full flex items-center justify-center text-[10px] ${
                        status === "done" ? "bg-green-500/20 text-green-500" :
                        status === "active" ? "bg-primary/20 text-primary animate-pulse" :
                        "bg-muted text-muted-foreground"
                      }`}>
                        {status === "done" ? "✓" : status === "active" ? "●" : "○"}
                      </div>
                      <span className={
                        status === "done" ? "text-green-500" :
                        status === "active" ? "text-foreground font-medium" :
                        "text-muted-foreground"
                      }>{p.label}</span>
                      {status === "active" && <LoaderIcon style={{ marginLeft: "auto" }} />}
                    </div>
                  );
                })}
              </div>

              {/* Current step */}
              {pipelineStatus?.step && (
                <div className="rounded-md bg-muted/50 px-3 py-2">
                  <p className="text-xs text-muted-foreground">Current step</p>
                  <p className="text-sm font-mono">{pipelineStatus.step}</p>
                </div>
              )}
            </>
          )}
        </div>

        {/* ─── ARTIFACTS PANEL ───────────────────────────── */}
        <div className="rounded-lg border border-border bg-card p-4 space-y-3 overflow-y-auto">
          <h2 className="text-sm font-semibold text-foreground">Artifacts</h2>
          
          {!artifacts ? (
            <div className="flex flex-col items-center justify-center h-40 text-center text-muted-foreground">
              <p className="text-xs">Completed books and exports appear here</p>
            </div>
          ) : (
            <div className="space-y-2">
              {artifacts.files?.map((file) => (
                <a key={file.name} href={file.url}
                  className="flex items-center gap-3 rounded-md border border-border p-3 hover:bg-accent transition-colors cursor-pointer">
                  <DownloadIcon />
                  <div>
                    <p className="text-sm font-medium">{file.label}</p>
                    <p className="text-xs text-muted-foreground">{file.size}</p>
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
